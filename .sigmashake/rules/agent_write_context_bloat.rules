# agent_write_context_bloat.rules — Prevent LLM context token waste from bloated files.
# Technology: agent | Capability: write
# Catches three recurring patterns that inflate token costs without adding value:
# 1. Hook scripts that echo on every allowed tool call
# 2. Duplicated skills/commands tables across CLAUDE.md files
# 3. Oversized skill definitions that consume tokens on every invocation

rule ask-hook-echo-on-allow {
  enabled true
  priority 75
  severity warning
  LOG write
  IF path GLOB "**/hooks/*.sh" AND content LINE_CONTAINS "echo" AND content CONTAINS "\"allow\""
  OR path GLOB "**/hooks/*.sh" AND content LINE_CONTAINS "echo" AND content CONTAINS "'allow'"
  MESSAGE "Hook script echoes on every allow decision. At ~10 tokens per tool call, this costs 500-1,500 tokens per session with no agent value — agents do not need confirmation that a tool was allowed."
}

rule ask-claudemd-duplicate-table {
  enabled true
  priority 50
  severity warning
  LOG write
  IF path ENDS_WITH "CLAUDE.md" AND content CONTAINS "| Skill | Description |"
  OR path ENDS_WITH "CLAUDE.md" AND content CONTAINS "| Script | What it does |"
  MESSAGE "Writing a large reference table to a CLAUDE.md. These files are loaded into every conversation — duplicating tables across CLAUDE.md files wastes hundreds of tokens per conversation."
}

rule log-skill-file-write {
  enabled true
  priority 20
  severity info
  LOG write
  IF path ENDS_WITH "SKILL.md"
  MESSAGE "Skill file written. Large SKILL.md files are injected entirely on each invocation — keep skills under 300 lines. Split into sub-skills or use lazy-loaded phase files for complex workflows."
}
